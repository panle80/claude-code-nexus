# Claude Code Nexus — 环境变量配置
# 复制此文件为 .env 并填入实际值

# [必需] JWT 签名密钥 — 请用随机字符串，例如: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret

# [必需] CORS 允许的前端域名，多个用逗号分隔
CORS_ORIGIN=http://localhost:5173

# [可选] 服务端口
PORT=3001

# [可选] Claude CLI 路径
CLAUDE_PATH=/usr/bin/claude

# [可选] Claude 请求超时（毫秒）
CLAUDE_TIMEOUT=600000

# [必需] 用户数据存储路径（必须使用绝对路径）
USER_DATA_ROOT=/home/panle/web/data/users

# [可选] Anthropic API 兼容接口配置（用于 Claude CLI 认证）
# 不设置时，CLI 将从 $HOME/.claude/settings.json 读取凭据
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_AUTH_TOKEN=sk-your-api-key
# ANTHROPIC_MODEL=deepseek-v4-pro[1m]
# ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-pro[1m]
# ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro[1m]
# ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro[1m]

# [可选] 管理员用户名，多个用逗号分隔（用于技能市场上传/删除权限）
ADMIN_USERNAMES=
